# Cloudflare Turnstile — gates the /contact vCard download so bots can't
# scrape the contact details. Create a free widget (sitekey + secret) at
# https://dash.cloudflare.com → Turnstile, add your domains, then set both
# values here for local dev AND in your Vercel project's Environment Variables.
#
# Copy this file to .env.local and fill in the values (.env.local is gitignored).
#
# Without these, /contact still renders (using Cloudflare's test sitekey) but
# the download fails closed in production until the real secret is set.

# Public site key — sent to the browser. Safe to expose.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Secret key — server-only. Never commit the real value.
TURNSTILE_SECRET_KEY=
